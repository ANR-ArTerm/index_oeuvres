{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "http://example.com/artwork.schema.json",
  "title": "Artwork Entry",
  "type": "object",
  "required": [
    "id",
    "entry_type",
    "title"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "QID_wikidata": {
      "type": "string"
    },
    "entry_type": {
      "type": "string",
      "enum": ["artwork"]
    },
    "title": {
      "type": "string"
    },
    "creator": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["xml_id", "role"],
        "properties": {
          "xml_id": {
            "type": "string"
          },
          "role": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "dateCreated": {
      "type": "object",
      "properties": {
        "startYear": {
            "type": "integer",
            "minimum": -9999,
            "maximum": 9999
        },
        "endYear": {
            "type": "integer",
            "minimum": -9999,
            "maximum": 9999
        },
        "text": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "materialsAndTechniques": {
      "type": "string"
    },
    "location": {
        "oneOf": [
            {
            "type": "object",
            "required": ["type", "institution"],
            "properties": {
                "type": {
                "type": "string",
                "enum": ["holding_institution"]
                },
                "institution": {
                "type": "object",
                "required": ["name"],
                "properties": {
                    "name": { "type": "string" },
                    "place": { "type": "string" },
                    "inventory_number": { "type": "string" },
                    "url": { "type": "string", "format": "uri" }
                },
                "additionalProperties": false
                }
            },
            "additionalProperties": false
            },
            {
            "type": "object",
            "required": ["type", "place"],
            "properties": {
                "type": {
                "type": "string",
                "enum": ["place"]
                },
                "place": {
                "type": "object",
                "properties": {
                    "city": { "type": "string" },
                    "country": { "type": "string" },
                    "coordinates": {
                    "type": "object",
                    "properties": {
                        "latitude": { "type": "number" },
                        "longitude": { "type": "number" }
                    },
                    "required": ["latitude", "longitude"],
                    "additionalProperties": false
                    }
                },
                "additionalProperties": false
                }
            },
            "additionalProperties": false
            },
            {
            "type": "object",
            "required": ["type"],
            "properties": {
                "type": {
                "type": "string",
                "enum": ["unlocated", "multiple_locations"]
                }
            },
            "additionalProperties": false
            }
        ]
    },
    "related_works": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["link_type", "xml_id_work"],
        "properties": {
          "link_type": {
            "type": "string"
          },
          "xml_id_work": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "contained_by_ensemble": {
      "type": "object",
      "properties": {
        "link_type": {
          "type": "string"
        },
        "xml_id_work": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "bibliography": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["zotero_key"],
        "properties": {
          "zotero_key": {
            "type": "string"
          },
          "location": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "illustrations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "url"],
        "properties": {
          "id": {
            "type": "integer"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "copyright": {
            "type": "string"
          },
          "caption": {
            "type": "string"
          },
          "storage": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "description": {
      "type": "string"
    },
    "commentary": {
      "type": "string"
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["date", "type", "author"],
        "properties": {
          "date": {
            "type": "string",
            "format": "date-time"
          },
          "type": {
            "type": "string",
            "enum": ["created", "modified"]
          },
          "author": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "minItems": 1
    }
  },
  "additionalProperties": false
}